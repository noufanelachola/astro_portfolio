---
import Icon from '../Icon.astro';

interface Profile {
  name: string;
  handle: string;
  role: string;
  company: string;
  location: string;
  email: string;
  website: string;
  meta: string;
  avatar: string;
}

const { profile } = Astro.props as { profile: Profile };
---

<article class="profile-card">
  <div class="avatar-wrap">
    <img
      src={profile.avatar}
      alt={`${profile.name} GitHub avatar`}
      width="176"
      height="176"
      loading="eager"
    />
  </div>

  <div class="profile-heading">
    <h1>{profile.name}</h1>
    <p>{profile.handle}</p>
    <div class="profile-icon-div">
      <span><Icon name="sparkle" /><p>{profile.role}</p></span>
      <span><Icon name="map" /><p>{profile.location}</p></span>
    </div>
  </div>
</article>

<style>
  .profile-card {
    display: grid;
    justify-items: end;
    min-height: 420px;
    width: 100%;
    padding: 20px 0;
    text-align: right;
    overflow: hidden;
  }

  .avatar-wrap {
    position: relative;
    width: 176px;
    height: 176px;
    margin: 0 0 18px auto;
    padding: 0;
    border-radius: 50%;
    background: transparent;
    box-shadow: none;
  }

  .avatar-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
  }

  .profile-heading h1 {
    margin: 0;
    color: var(--paper-ink);
    font-size: 1.42rem;
    letter-spacing: 0;
  }

  .profile-heading p {
    /* margin: 4px 0 14px; */
    margin: 0px 0px 2px 0px;
    color: var(--paper-ink-soft);
    font-size: 0.94rem;
  }

  .profile-heading .profile-icon-div {
    display: flex;
    flex-direction: column;
    gap: 0px;
  }

  .profile-heading .profile-icon-div span {
    /* display: inline-flex; */
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-end;
    gap: 4px;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: var(--paper-ink);
    font-size: 0.82rem;
  }

  .profile-heading .profile-icon-div span p{
    margin: 0;
    color: var(--paper-ink);
    font-size: 0.82rem;
  }

  .profile-heading svg {
    width: 15px;
    height: 15px;
    flex: 0 0 auto;
    color: var(--paper-accent);
  }

  @media (max-width: 820px) {
    .profile-card {
      justify-items: center;
      min-height: auto;
      padding: 4px 0 0;
      text-align: center;
    }

    .avatar-wrap {
      margin-right: auto;
      margin-left: auto;
    }

    .profile-heading .profile-icon-div span {
      justify-content: center;
    }
    .profile-heading .profile-icon-div span p {
      justify-content: center;
    }
  }
</style>
